# Настройки сервера
SERVER_HOST=0.0.0.0
SERVER_PORT=10000
SERVER_RELOAD=True

# SSL сертификаты
SSL_KEYFILE=server.key
SSL_CERTFILE=server.crt

# 🔐 ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ БЕЗОПАСНОСТИ
# ⚠️ ВНИМАНИЕ: Эти ключи ДОЛЖНЫ совпадать с клиентом!

# Шифрование E2E (ДОЛЖНО СОВПАДАТЬ С RC_ENCRYPTION_KEY на клиенте!)
# Генерация: openssl rand -hex 32
SERVER_ENCRYPTION_KEY=

# Соль для PBKDF2 (ДОЛЖНА СОВПАДАТЬ С RC_ENCRYPTION_SALT на клиенте!)
# Генерация: openssl rand -base64 32
SERVER_ENCRYPTION_SALT=

# JWT аутентификация (только для сервера)
# Генерация: openssl rand -hex 64
# По умолчанию для локальной разработки используем тот же секрет, что и в auth_service (SECRET_KEY).
# В production задавайте явный, уникальный `JWT_SECRET_KEY`.
JWT_SECRET_KEY=${SECRET_KEY:-super-secret-jwt-key-change-this-in-production}
JWT_EXPIRE_MINUTES=60

# Валидация команд
COMMAND_VALIDATION_MODE=strict
MAX_COMMAND_LENGTH=1000

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS настройки
CORS_ORIGINS=http://localhost:3000

# Ограничения
MAX_CONNECTIONS=1000
MAX_COMMAND_TIMEOUT=300
MAX_OUTPUT_SIZE=10485760

# Мониторинг
ENABLE_METRICS=True
METRICS_PORT=9090

# Файловые трансферы
FILE_ALLOWED_BASE_DIR=/var/remote-client/files
FILE_MAX_TRANSFER_SIZE=104857600
FILE_PER_CLIENT_QUOTA_BYTES=1073741824

# WebSocket лимиты
WS_MAX_MESSAGE_BYTES=1048576
WS_MAX_MESSAGES_PER_MINUTE=600

# ⚠️ TLS DOWNGRADE (НЕ ВКЛЮЧАЙТЕ В ПРОДАКШЕНЕ!)
# Разрешить откат на незащищенное соединение (только для отладки!)
ALLOW_TLS_DOWNGRADE=false
