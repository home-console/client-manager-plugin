# Настройки сервера
SERVER_HOST=0.0.0.0
SERVER_PORT=10000
SERVER_RELOAD=True

# SSL сертификаты
SSL_KEYFILE=server.key
SSL_CERTFILE=server.crt

# Шифрование E2E
SERVER_ENCRYPTION_KEY=change-this-to-random-secure-key-in-production
ENCRYPTION_SALT=remote-client-salt-change-this

# JWT аутентификация
JWT_SECRET_KEY=change-this-jwt-secret-key-in-production
JWT_EXPIRE_MINUTES=60

# Валидация команд
COMMAND_VALIDATION_MODE=strict
MAX_COMMAND_LENGTH=1000

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS настройки
CORS_ORIGINS=http://localhost:*,https://localhost:*

# Ограничения
MAX_CONNECTIONS=1000
MAX_COMMAND_TIMEOUT=300
MAX_OUTPUT_SIZE=10485760

# Мониторинг
ENABLE_METRICS=True
METRICS_PORT=9090
